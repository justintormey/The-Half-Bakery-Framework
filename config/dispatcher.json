{
  "max_concurrent": 3,
  "agent_timeout_minutes": 45,
  "projects_root": "~/PROJECTS",
  "agents_root": "~/PROJECTS/half-bakery/agents",
  "github_repo": "justintormey/half-bakery",
  "github_project_number": 1,
  "polish_epic_number": 124,
  "state_dir": "~/.half-bakery",
  "claude_permission_mode": "bypassPermissions",
  "spanning_projects": ["half-bakery"],
  "default_provider": "claude",
  "providers": {
    "claude": {
      "type": "anthropic"
    },
    "local": {
      "type": "local",
      "base_url": "http://192.168.0.206:8080/v1",
      "model": "qwen3-coder",
      "ctx_size": 131072,
      "max_turns": 50,
      "fallback_provider": "claude"
    }
  },
  "agent_models": {
    "founding-engineer": "sonnet",
    "designer": "sonnet",
    "documentarian": "sonnet",
    "review": "sonnet"
  },
  "budget": {
    "work_hours": {"start": 9, "end": 18},
    "work_days": [0, 1, 2, 3, 4],
    "conservative_max": 1,
    "moderate_max": 1,
    "aggressive_max": 4,
    "reserve_pct_work_hours": 40,
    "reserve_pct_shoulder": 20
  },
  "evaluation": {
    "max_retries": 2,
    "max_skeptic_rejections": 3,
    "max_merge_retries": 3,
    "run_tests": true,
    "llm_spot_check": false
  },
  "discovery": {
    "enabled": true,
    "max_issues_per_cycle": 3,
    "cooldown_days": 7,
    "scan_todos": true,
    "scan_deps": true,
    "scan_security": true,
    "scan_gaps": true,
    "scan_vision": true,
    "vision_cooldown_days": 1
  },
  "test_commands": {
    "default": null
  },
  "project_overrides": {}
}
